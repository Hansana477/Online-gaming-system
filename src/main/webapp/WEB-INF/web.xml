<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
         
   <servlet>
       <servlet-name>gameinsert</servlet-name>
       <servlet-class>com.games.gameinsert</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>gameinsert</servlet-name>
       <url-pattern>/insertgame</url-pattern>
   </servlet-mapping>     
   
   <servlet>
       <servlet-name>updategames</servlet-name>
       <servlet-class>com.games.Updategameservlet</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>updategames</servlet-name>
       <url-pattern>/updategame</url-pattern>
   </servlet-mapping> 
   
   <servlet>
       <servlet-name>deletegame</servlet-name>
       <servlet-class>com.games.DeleteGameServlet</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>deletegame</servlet-name>
       <url-pattern>/delete</url-pattern>
   </servlet-mapping> 
   
   <servlet>
       <servlet-name>feedbackinsert</servlet-name>
       <servlet-class>com.feedback.FeedbackInsert</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>feedbackinsert</servlet-name>
       <url-pattern>/insert</url-pattern>
   </servlet-mapping>     
   
   <servlet>
       <servlet-name>viewfeedback</servlet-name>
       <servlet-class>com.feedback.ViewFeedback</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>viewfeedback</servlet-name>
       <url-pattern>/viewfeedback</url-pattern>
   </servlet-mapping>     

   <servlet>
       <servlet-name>editfeedback</servlet-name>
       <servlet-class>com.feedback.EditFeedback</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>editfeedback</servlet-name>
       <url-pattern>/editfeedback</url-pattern>
   </servlet-mapping>     

   <servlet>
       <servlet-name>deletefeedback</servlet-name>
       <servlet-class>com.feedback.DeleteFeedback</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>deletefeedback</servlet-name>
       <url-pattern>/deletefeedback</url-pattern>
   </servlet-mapping> 
   
   <servlet>
       <servlet-name>login</servlet-name>
       <servlet-class>com.log.LoginServlet</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>login</servlet-name>
       <url-pattern>/login</url-pattern>
   </servlet-mapping>

   <servlet>
       <servlet-name>signup</servlet-name>
       <servlet-class>com.log.SignupServlet</servlet-class>
   </servlet>
   
   <servlet-mapping>
       <servlet-name>signup</servlet-name>
       <url-pattern>/signup</url-pattern>
   </servlet-mapping>  
   
   
</web-app>